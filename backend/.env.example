# Server
PORT=8080
HOST=0.0.0.0

# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/gym-tracker?sslmode=disable

# JWT (generate random secrets for production)
JWT_ACCESS_SECRET=your-access-secret-change-me-in-production
JWT_REFRESH_SECRET=your-refresh-secret-change-me-in-production

# JWT expiry (optional, defaults shown)
# JWT_ACCESS_EXPIRY=15m
# JWT_REFRESH_EXPIRY=168h

# Media (optional)
# MEDIA_ROOT_DIR=./media
# MEDIA_GIFS_DIR=gifs
# MEDIA_THUMBNAILS_DIR=thumbnails
# DATASET_PATH=
